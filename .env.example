# Enables Claude Haiku 4.5 responses from "Ask Harsh's AI" (src/app/api/ask/route.ts). Without it the route degrades to a 503 "offline" response. Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Enables vector (embedding) retrieval for the assistant's corpus via scripts/embed-corpus.mjs and src/lib/assistant/retrieval.ts. Without it, retrieval falls back to lexical scoring. Get one at https://dashboard.voyageai.com/api-keys
VOYAGE_API_KEY=

# Enables rate limiting on /api/ask (Upstash Redis REST URL). Without it, rate limiting is skipped entirely. Get one from your database's "REST API" tab at https://console.upstash.com
UPSTASH_REDIS_REST_URL=

# Enables rate limiting on /api/ask (Upstash Redis REST token, paired with the URL above). Same "REST API" tab at https://console.upstash.com
UPSTASH_REDIS_REST_TOKEN=
